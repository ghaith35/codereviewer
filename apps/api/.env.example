NODE_ENV=development
PORT=8080

# PostgreSQL (local: docker-compose, prod: Render)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codereviewer

# Redis (local: docker-compose, prod: Upstash)
REDIS_URL=redis://localhost:6379

# JWT — generate: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=CHANGE_ME_64_BYTE_BASE64_STRING

# Token encryption — generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must be exactly 32 bytes = 44 base64 chars
TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_STRING_44_CHARS

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback

# Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173
